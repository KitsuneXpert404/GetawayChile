# ====================================================================
# GETAWAY CHILE ERP — Variables de Entorno
# ====================================================================
# Copia este archivo como .env en tu directorio local (no subir .env a git!)
# En PRODUCCIÓN todas estas variables se configuran en Render > Environment
# ====================================================================

# --------------------------------------------------------------------
# DJANGO BASE
# --------------------------------------------------------------------
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --------------------------------------------------------------------
# BASE DE DATOS
# --------------------------------------------------------------------
# Para producción en Render: Render provee DATABASE_URL automáticamente
# Para desarrollo local con PostgreSQL (opcional):
# USE_POSTGRES=true
# PG_DATABASE=getaway_chile
# PG_USER=postgres
# PG_PASSWORD=tu_password
# PG_HOST=localhost
# PG_PORT=5432

# En producción (Render lo completa automáticamente):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --------------------------------------------------------------------
# CSRF (PRODUCCIÓN — obligatorio cuando DEBUG=False)
# Reemplaza con tu URL real de Render y/o tu dominio propio
# --------------------------------------------------------------------
# CSRF_TRUSTED_ORIGINS=https://getaway-chile-erp.onrender.com,https://sistema.getawaychile.cl

# --------------------------------------------------------------------
# CLOUDINARY — Almacenamiento de fotos de tours
# 1. Crear cuenta en https://cloudinary.com (gratis, 25GB)
# 2. Dashboard > API Keys > copiar "API Environment variable"
# Formato: cloudinary://api_key:api_secret@cloud_name
# --------------------------------------------------------------------
# CLOUDINARY_URL=cloudinary://123456789:AbCdEfGhIjK@mi-cloud-name

# --------------------------------------------------------------------
# EMAIL SMTP — Correos corporativos
# --------------------------------------------------------------------
# Opción A: Google Workspace
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=sistema@getawaychile.cl
#   EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx  (App Password de Google, NO la contraseña normal)
#
# Opción B: Zoho Mail (más económico)
#   EMAIL_HOST=smtp.zoho.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=sistema@getawaychile.cl
#   EMAIL_HOST_PASSWORD=tu_password_zoho

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Getaway Chile <noreply@getawaychile.cl>

# --------------------------------------------------------------------
# SUPERUSUARIO INICIAL (solo para el primer deploy en Render)
# build.sh ejecuta: python manage.py createsuperuser --noinput
# --------------------------------------------------------------------
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@getawaychile.cl
# DJANGO_SUPERUSER_PASSWORD=CambiarEsto123!
