# ====================================================================
# GETAWAY CHILE ERP — Variables de Entorno
# ====================================================================
# Copia este archivo como .env en tu directorio local (no subir .env a git).
# En PRODUCCIÓN (Render) configura todas estas variables en Dashboard > Environment.
# ====================================================================

# --------------------------------------------------------------------
# DJANGO BASE
# --------------------------------------------------------------------
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# --------------------------------------------------------------------
# BASE DE DATOS
# --------------------------------------------------------------------
# Render provee DATABASE_URL automáticamente al enlazar la base de datos.
# Local con PostgreSQL (opcional):
# USE_POSTGRES=true
# PG_DATABASE=getaway_chile
# PG_USER=postgres
# PG_PASSWORD=tu_password
# PG_HOST=localhost
# PG_PORT=5432

# --------------------------------------------------------------------
# CSRF (obligatorio en producción cuando DEBUG=False)
# --------------------------------------------------------------------
# Añade la URL exacta de tu servicio Render y, si aplica, tu dominio propio.
# Ejemplo: https://getaway-chile-erp.onrender.com
# Con dominio: https://getaway-chile-erp.onrender.com,https://sistema.getawaychile.cl
# CSRF_TRUSTED_ORIGINS=https://getaway-chile-erp.onrender.com

# --------------------------------------------------------------------
# CLOUDINARY — Almacenamiento de vouchers e imágenes
# --------------------------------------------------------------------
# 1. Crear cuenta en https://cloudinary.com (gratis, 25GB)
# 2. Dashboard > API Keys > copiar "API Environment variable"
# Formato: cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_URL=cloudinary://xxx:yyy@zzz

# --------------------------------------------------------------------
# EMAIL SMTP — Necesario para que los correos funcionen en producción
# --------------------------------------------------------------------
# En local con console (solo imprime en terminal):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# En producción (Render) usa SMTP. Opción A — Google Workspace:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=sistema@getawaychile.cl
# EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
# DEFAULT_FROM_EMAIL=Getaway Chile <sistema@getawaychile.cl>
# (EMAIL_HOST_PASSWORD = Contraseña de aplicación de Google, NO la contraseña normal)

# Opción B — Zoho Mail (si usas Zoho para getawaychile.cl):
# EMAIL_HOST=smtp.zoho.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=sistema@getawaychile.cl
# EMAIL_HOST_PASSWORD=tu_contraseña_zoho
# DEFAULT_FROM_EMAIL=Getaway Chile <sistema@getawaychile.cl>

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Getaway Chile <noreply@getawaychile.cl>

# --------------------------------------------------------------------
# SUPERUSUARIO INICIAL (solo primer deploy en Render)
# --------------------------------------------------------------------
# build.sh ejecuta: python manage.py createsuperuser --noinput
# Solo se crea si no existe ya un superusuario.
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@getawaychile.cl
# DJANGO_SUPERUSER_PASSWORD=CambiarEsto123!

# --------------------------------------------------------------------
# OPCIONAL — Twilio (WhatsApp)
# --------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --------------------------------------------------------------------
# OPCIONAL — Dominio en enlaces de correo
# --------------------------------------------------------------------
# Si quieres que los enlaces (ej. restablecer contraseña) usen siempre este dominio:
# SITE_DOMAIN=sistema.getawaychile.cl
# Por defecto Django usa la URL desde la que el usuario accede (ej. .onrender.com).
